# PostgreSQL — host and port for the NestJS process
# DB_PORT must match the Docker Compose host-port mapping (5433 → container 5432)
DB_HOST=localhost
DB_PORT=5433
DB_USER=ocr_user
DB_PASSWORD=change_me
DB_NAME=ocr_db

# Qdrant vector database (bound to loopback in docker-compose.yml)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=change_me

# Redis — used by BullMQ for the background embed queue
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenAI — required for embeddings (text-embedding-3-small) and chat (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# CORS — must match the frontend origin served by Vite
CORS_ORIGIN=http://localhost:5173

# HTTP server port (optional — defaults to 3000)
# PORT=3000
